## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# .NET test results
[Tt]est[Rr]esult*/
[Bb]enchmarkDotNet.Artifacts/

# Visual Studio cache/options directory
.vs/

# Visual Studio Code
.vscode/

# Rider / ReSharper
.idea/
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# MonoDevelop / Xamarin Studio
*.userprefs

# NuGet packages
*.nupkg
*.snupkg
packages/
!packages/build/
*.nuget.props
*.nuget.targets

# NuGet v3 local cache folders if ever created in repo
.nuget/

# Package output folders
artifacts/

# MSBuild binary and temp files
*.ilk
*.meta
*.obj
*.pch
*.pdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.tlog
*.vspscc
*.vssscc
.builds

# Generated files
Generated\ Files/

# Publish output
publish/

# One-off local publish/package folders
AppPackages/
BundleArtifacts/
PackageArtifacts/

# Azure / web publish settings that may contain secrets
*.Publish.xml
*.pubxml.user

# IIS Express
.vs/config/

# SQL / local db files
*.mdf
*.ldf
*.ndf

# LocalDB
*.dbmdl

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
*.cache
*.pidb
*.svclog
*.scc

# Node if ever added for docs/site tooling
node_modules/

# Coverage / reports
coverage/
*.coverage
*.coveragexml

# JetBrains
*.sln.iml

# Backup files
*.bak
*.backup
*.orig

# Environment / secrets
.env
.env.*
secrets.json

# Ignore copied files
* - Copy.cs
* - Copy.md
* - Copy.txt

# Keep package icon if used
!src/TrackRoad.Api.Client/icon.png